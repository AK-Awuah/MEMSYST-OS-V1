rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().permissions.hasAny(['*']);
    }

    function hasPermission(perm) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().permissions.hasAny(['*', perm]);
    }

    function userTenantId() {
      return (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? getUserData().tenantId
        : null;
    }

    // Use on reads (resource exists)
    function sameTenantAsResource() {
      return isAuthenticated() && resource.data.tenantId == userTenantId();
    }

    // Use on writes (incoming data)
    function sameTenantAsRequest() {
      return isAuthenticated() && request.resource.data.tenantId == userTenantId();
    }

    // ============================================
    // USERS
    // /users/{userId}
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId
          || isSuperAdmin()
          || (hasPermission('users:read') && sameTenantAsResource()));

      // Allow users to create their own profile on first login (bootstrap)
      allow create: if isAuthenticated() && request.auth.uid == userId;

      allow update: if isAuthenticated()
        && (request.auth.uid == userId || hasPermission('users:write'))
        && (isSuperAdmin() || request.resource.data.tenantId == userTenantId());

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // ROLES
    // /roles/{roleId}
    // ============================================
    match /roles/{roleId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || (hasPermission('roles:read') && sameTenantAsResource()));

      allow create: if hasPermission('roles:write')
        && (isSuperAdmin() || sameTenantAsRequest());

      allow update: if hasPermission('roles:write')
        && (isSuperAdmin() || sameTenantAsResource());

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // PERMISSIONS (read-only reference data)
    // /permissions/{permKey}
    // ============================================
    match /permissions/{permKey} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================
    // SESSIONS
    // /sessions/{sessionId}
    // ============================================
    match /sessions/{sessionId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
          || request.auth.uid == resource.data.userId
          || (hasPermission('sessions:read') && sameTenantAsResource()));

      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;

      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
          || hasPermission('sessions:write'));

      allow delete: if isAuthenticated()
        && (isSuperAdmin()
          || hasPermission('sessions:write')
          || request.auth.uid == resource.data.userId);
    }

    // ============================================
    // SECURITY EVENTS (append-only audit trail)
    // /securityEvents/{eventId}
    // ============================================
    match /securityEvents/{eventId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
          || (hasPermission('audit:read') && sameTenantAsResource()));

      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // TENANTS
    // /tenants/{tenantId}
    // ============================================
    match /tenants/{tenantId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || tenantId == userTenantId());

      allow create: if hasPermission('tenants:write');

      allow update: if hasPermission('tenants:write')
        && (isSuperAdmin() || tenantId == userTenantId());

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // TENANT SETTINGS
    // /tenantSettings/{tenantId}
    // ============================================
    match /tenantSettings/{tenantId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || tenantId == userTenantId());

      allow write: if hasPermission('settings:write')
        && (isSuperAdmin() || tenantId == userTenantId());
    }

    // ============================================
    // FORM SUBMISSIONS
    // /formSubmissions/{docId}
    // ============================================
    match /formSubmissions/{docId} {
      // Public can create (from marketing website)
      allow create: if true;

      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('forms:read'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('forms:write'));

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // LEADS
    // /leads/{docId}
    // ============================================
    match /leads/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('leads:read'));

      allow create: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('leads:write'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('leads:write'));

      allow delete: if isSuperAdmin();

      // Lead activities subcollection
      match /activities/{activityId} {
        allow read: if isAuthenticated()
          && (isSuperAdmin() || hasPermission('leads:read'));
        allow create: if isAuthenticated()
          && (isSuperAdmin() || hasPermission('leads:write'));
        allow update, delete: if isSuperAdmin();
      }
    }

    // ============================================
    // CRM OPPORTUNITIES
    // /crm_opportunities/{docId}
    // ============================================
    match /crm_opportunities/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('crm:read'));

      allow create: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('crm:write'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('crm:write'));

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // ORGANIZATION PROSPECTS
    // /organization_prospects/{docId}
    // ============================================
    match /organization_prospects/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('organizations:read'));

      allow create: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('organizations:write'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('organizations:write'));

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // NOTIFICATIONS
    // /notifications/{docId}
    // ============================================
    match /notifications/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || resource.data.recipientId == request.auth.uid);

      allow create: if isAuthenticated();

      allow update: if isAuthenticated()
        && (isSuperAdmin() || resource.data.recipientId == request.auth.uid);

      allow delete: if false;
    }

    // ============================================
    // AUDIT LOGS (immutable)
    // /auditLogs/{logId}
    // ============================================
    match /auditLogs/{logId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('audit:read'));

      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // Deny everything else by default
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

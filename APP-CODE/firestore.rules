rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().permissions.hasAny(['*']);
    }

    function hasPermission(perm) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && getUserData().permissions.hasAny(['*', perm]);
    }

    function userTenantId() {
      return (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)))
        ? getUserData().tenantId
        : null;
    }

    // Use on reads (resource exists)
    function sameTenantAsResource() {
      return isAuthenticated() && resource.data.tenantId == userTenantId();
    }

    // Use on writes (incoming data)
    function sameTenantAsRequest() {
      return isAuthenticated() && request.resource.data.tenantId == userTenantId();
    }

    // ============================================
    // USERS
    // /users/{userId}
    // ============================================
    match /users/{userId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId
          || isSuperAdmin()
          || (hasPermission('users:read') && sameTenantAsResource()));

      // Allow users to create their own profile on first login (bootstrap)
      allow create: if isAuthenticated() && request.auth.uid == userId;

      allow update: if isAuthenticated()
        && (request.auth.uid == userId || hasPermission('users:write'))
        && (isSuperAdmin() || request.resource.data.tenantId == userTenantId());

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // ROLES
    // /roles/{roleId}
    // ============================================
    match /roles/{roleId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || (hasPermission('roles:read') && sameTenantAsResource()));

      allow create: if hasPermission('roles:write')
        && (isSuperAdmin() || sameTenantAsRequest());

      allow update: if hasPermission('roles:write')
        && (isSuperAdmin() || sameTenantAsResource());

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // PERMISSIONS (read-only reference data)
    // /permissions/{permKey}
    // ============================================
    match /permissions/{permKey} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================
    // SESSIONS
    // /sessions/{sessionId}
    // ============================================
    match /sessions/{sessionId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
          || request.auth.uid == resource.data.userId
          || (hasPermission('sessions:read') && sameTenantAsResource()));

      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId;

      allow update: if isAuthenticated()
        && (request.auth.uid == resource.data.userId
          || hasPermission('sessions:write'));

      allow delete: if isAuthenticated()
        && (isSuperAdmin()
          || hasPermission('sessions:write')
          || request.auth.uid == resource.data.userId);
    }

    // ============================================
    // SECURITY EVENTS (append-only audit trail)
    // /securityEvents/{eventId}
    // ============================================
    match /securityEvents/{eventId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin()
          || (hasPermission('audit:read') && sameTenantAsResource()));

      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // TENANTS
    // /tenants/{tenantId}
    // ============================================
    match /tenants/{tenantId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || tenantId == userTenantId());

      allow create: if hasPermission('tenants:write');

      allow update: if hasPermission('tenants:write')
        && (isSuperAdmin() || tenantId == userTenantId());

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // TENANT SETTINGS
    // /tenantSettings/{tenantId}
    // ============================================
    match /tenantSettings/{tenantId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || tenantId == userTenantId());

      allow write: if hasPermission('settings:write')
        && (isSuperAdmin() || tenantId == userTenantId());
    }

    // ============================================
    // FORM SUBMISSIONS
    // /formSubmissions/{docId}
    // ============================================
    match /formSubmissions/{docId} {
      // Public can create (from marketing website)
      allow create: if true;

      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('forms:read'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('forms:write'));

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // LEADS
    // /leads/{docId}
    // ============================================
    match /leads/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('leads:read'));

      allow create: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('leads:write'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('leads:write'));

      allow delete: if isSuperAdmin();

      // Lead activities subcollection
      match /activities/{activityId} {
        allow read: if isAuthenticated()
          && (isSuperAdmin() || hasPermission('leads:read'));
        allow create: if isAuthenticated()
          && (isSuperAdmin() || hasPermission('leads:write'));
        allow update, delete: if isSuperAdmin();
      }
    }

    // ============================================
    // CRM OPPORTUNITIES
    // /crm_opportunities/{docId}
    // ============================================
    match /crm_opportunities/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('crm:read'));

      allow create: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('crm:write'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('crm:write'));

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // ORGANIZATION PROSPECTS
    // /organization_prospects/{docId}
    // ============================================
    match /organization_prospects/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('organizations:read'));

      allow create: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('organizations:write'));

      allow update: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('organizations:write'));

      allow delete: if isSuperAdmin();
    }

    // ============================================
    // NOTIFICATIONS
    // /notifications/{docId}
    // ============================================
    match /notifications/{docId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || resource.data.recipientId == request.auth.uid);

      allow create: if isAuthenticated();

      allow update: if isAuthenticated()
        && (isSuperAdmin() || resource.data.recipientId == request.auth.uid);

      allow delete: if false;
    }

    // ============================================
    // AUDIT LOGS (immutable)
    // /auditLogs/{logId}
    // ============================================
    match /auditLogs/{logId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('audit:read'));

      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // FINANCIAL — WALLETS
    // /wallets/{walletId}
    // ============================================
    match /wallets/{walletId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // FINANCIAL — TRANSACTIONS
    // /transactions/{txnId}
    // ============================================
    match /transactions/{txnId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if false;
    }

    // ============================================
    // FINANCIAL — PAYMENTS
    // /payments/{paymentId}
    // ============================================
    match /payments/{paymentId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if false;
    }

    // ============================================
    // FINANCIAL — REVENUE RULES
    // /revenueRules/{ruleId}
    // ============================================
    match /revenueRules/{ruleId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // FINANCIAL — REVENUE DISTRIBUTIONS
    // /revenueDistributions/{distId}
    // ============================================
    match /revenueDistributions/{distId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update, delete: if false;
    }

    // ============================================
    // FINANCIAL — COMMISSION CONFIGS
    // /commissionConfigs/{configId}
    // ============================================
    match /commissionConfigs/{configId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // FINANCIAL — COMMISSIONS
    // /commissions/{commissionId}
    // ============================================
    match /commissions/{commissionId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update, delete: if false;
    }

    // ============================================
    // FINANCIAL — BILLS
    // /bills/{billId}
    // ============================================
    match /bills/{billId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if isSuperAdmin();
    }

    // ============================================
    // FINANCIAL — WITHDRAWALS
    // /withdrawals/{withdrawalId}
    // ============================================
    match /withdrawals/{withdrawalId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if isAuthenticated()
        && hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if false;
    }

    // ============================================
    // FINANCIAL — REFUNDS
    // /refunds/{refundId}
    // ============================================
    match /refunds/{refundId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if false;
    }

    // ============================================
    // FINANCIAL — RECEIPTS
    // /receipts/{receiptId}
    // ============================================
    match /receipts/{receiptId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || hasPermission('finance:read'));
      allow create: if hasPermission('finance:write');
      allow update: if hasPermission('finance:write');
      allow delete: if false;
    }

    // ============================================
    // FINANCIAL — FINANCIAL SETTINGS
    // /financialSettings/{tenantId}
    // ============================================
    match /financialSettings/{tenantId} {
      allow read: if isAuthenticated()
        && (isSuperAdmin() || tenantId == userTenantId());
      allow write: if hasPermission('finance:write');
    }

    // ============================================
    // EVENTS
    // /events/{docId}, /eventRegistrations/{docId}, /eventCertificates/{docId}, /workshops/{docId}, /eventsAuditLogs/{docId}
    // ============================================
    match /events/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('events:read'));
      allow create: if hasPermission('events:write');
      allow update: if hasPermission('events:write');
      allow delete: if isSuperAdmin();
    }
    match /eventRegistrations/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('events:read'));
      allow create: if hasPermission('events:write');
      allow update: if hasPermission('events:write');
      allow delete: if isSuperAdmin();
    }
    match /eventCertificates/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('events:read'));
      allow create: if hasPermission('events:write');
      allow update: if hasPermission('events:write');
      allow delete: if isSuperAdmin();
    }
    match /workshops/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('events:read'));
      allow create: if hasPermission('events:write');
      allow update: if hasPermission('events:write');
      allow delete: if isSuperAdmin();
    }
    match /eventsAuditLogs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // GOVERNANCE ENHANCED
    // /governanceElections, /governanceCandidates, /governanceVotes, /governanceCommittees, /governanceMeetings, /governanceResolutions, /governanceAuditLogs
    // ============================================
    match /governanceElections/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('governance:read'));
      allow create: if hasPermission('governance:write');
      allow update: if hasPermission('governance:write');
      allow delete: if isSuperAdmin();
    }
    match /governanceCandidates/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('governance:read'));
      allow create: if hasPermission('governance:write');
      allow update: if hasPermission('governance:write');
      allow delete: if isSuperAdmin();
    }
    match /governanceVotes/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('governance:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    match /governanceCommittees/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('governance:read'));
      allow create: if hasPermission('governance:write');
      allow update: if hasPermission('governance:write');
      allow delete: if isSuperAdmin();
    }
    match /governanceMeetings/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('governance:read'));
      allow create: if hasPermission('governance:write');
      allow update: if hasPermission('governance:write');
      allow delete: if isSuperAdmin();
    }
    match /governanceResolutions/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('governance:read'));
      allow create: if hasPermission('governance:write');
      allow update: if hasPermission('governance:write');
      allow delete: if isSuperAdmin();
    }
    match /governanceAuditLogs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // ANALYTICS & REPORTING
    // ============================================
    match /reports/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('analytics:read'));
      allow create: if hasPermission('analytics:write');
      allow update: if hasPermission('analytics:write');
      allow delete: if isSuperAdmin();
    }
    match /report_executions/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('analytics:read'));
      allow create: if hasPermission('analytics:write');
      allow update: if isSuperAdmin();
      allow delete: if false;
    }
    match /dashboards/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('analytics:read'));
      allow create: if hasPermission('analytics:write');
      allow update: if hasPermission('analytics:write');
      allow delete: if isSuperAdmin();
    }
    match /dashboard_widgets/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('analytics:read'));
      allow create: if hasPermission('analytics:write');
      allow update: if hasPermission('analytics:write');
      allow delete: if isSuperAdmin();
    }
    match /analytics_audit_logs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // INTEGRATION MARKETPLACE
    // ============================================
    match /api_keys/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('integrations:read'));
      allow create: if hasPermission('integrations:write');
      allow update: if hasPermission('integrations:write');
      allow delete: if isSuperAdmin();
    }
    match /webhooks/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('integrations:read'));
      allow create: if hasPermission('integrations:write');
      allow update: if hasPermission('integrations:write');
      allow delete: if isSuperAdmin();
    }
    match /webhook_deliveries/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('integrations:read'));
      allow create: if true;
      allow update, delete: if false;
    }
    match /integrations/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('integrations:read'));
      allow create: if hasPermission('integrations:write');
      allow update: if hasPermission('integrations:write');
      allow delete: if isSuperAdmin();
    }
    match /integration_audit_logs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // MOBILE
    // ============================================
    match /pwa_configs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('mobile:read'));
      allow write: if hasPermission('mobile:write');
    }
    match /offline_cache_rules/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('mobile:read'));
      allow create: if hasPermission('mobile:write');
      allow update: if hasPermission('mobile:write');
      allow delete: if isSuperAdmin();
    }
    match /mobile_versions/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('mobile:read'));
      allow create: if hasPermission('mobile:write');
      allow update: if hasPermission('mobile:write');
      allow delete: if isSuperAdmin();
    }
    match /mobile_audit_logs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // AI & AUTOMATION
    // ============================================
    match /ai_assistants/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('ai:read'));
      allow create: if hasPermission('ai:write');
      allow update: if hasPermission('ai:write');
      allow delete: if isSuperAdmin();
    }
    match /ai_conversations/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('ai:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }
    match /smart_analytics/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('ai:read'));
      allow create: if hasPermission('ai:write');
      allow update: if hasPermission('ai:write');
      allow delete: if isSuperAdmin();
    }
    match /workflow_suggestions/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('ai:read'));
      allow create: if hasPermission('ai:write');
      allow update: if hasPermission('ai:write');
      allow delete: if isSuperAdmin();
    }
    match /ai_audit_logs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // PLATFORM OPERATIONS
    // ============================================
    match /subscription_plans/{docId} {
      allow read: if isAuthenticated();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
    match /tenant_subscriptions/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('platform:read'));
      allow create: if hasPermission('platform:write');
      allow update: if hasPermission('platform:write');
      allow delete: if isSuperAdmin();
    }
    match /invoices/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('platform:read'));
      allow create: if hasPermission('platform:write');
      allow update: if hasPermission('platform:write');
      allow delete: if false;
    }
    match /support_tickets/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('platform:read'));
      allow create: if isAuthenticated();
      allow update: if hasPermission('platform:write');
      allow delete: if isSuperAdmin();
    }
    match /platform_partners/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('platform:read'));
      allow create: if hasPermission('platform:write');
      allow update: if hasPermission('platform:write');
      allow delete: if isSuperAdmin();
    }
    match /partner_tenants/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('platform:read'));
      allow create: if hasPermission('platform:write');
      allow update, delete: if isSuperAdmin();
    }
    match /platform_ops_audit_logs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // ADVERTISING
    // ============================================
    match /advertisements/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('advertising:read'));
      allow create: if hasPermission('advertising:write');
      allow update: if hasPermission('advertising:write');
      allow delete: if isSuperAdmin();
    }
    match /ad_campaigns/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('advertising:read'));
      allow create: if hasPermission('advertising:write');
      allow update: if hasPermission('advertising:write');
      allow delete: if isSuperAdmin();
    }
    match /sponsor_deals/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('advertising:read'));
      allow create: if hasPermission('advertising:write');
      allow update: if hasPermission('advertising:write');
      allow delete: if isSuperAdmin();
    }
    match /advertising_audit_logs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // TIERING & VISIBILITY
    // ============================================
    match /premium_accounts/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('tiering:read'));
      allow create: if hasPermission('tiering:write');
      allow update: if hasPermission('tiering:write');
      allow delete: if isSuperAdmin();
    }
    match /premium_listings/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('tiering:read'));
      allow create: if hasPermission('tiering:write');
      allow update: if hasPermission('tiering:write');
      allow delete: if isSuperAdmin();
    }
    match /visibility_rules/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('tiering:read'));
      allow create: if hasPermission('tiering:write');
      allow update: if hasPermission('tiering:write');
      allow delete: if isSuperAdmin();
    }
    match /tiering_audit_logs/{docId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || hasPermission('audit:read'));
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ============================================
    // Deny everything else by default
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
